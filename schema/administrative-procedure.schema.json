{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dimbinirina.dev/schemas/procedures/administrative-procedure.schema.json",
  "title": "Administrative Procedure v2",
  "type": "object",
  "required": [
    "schemaVersion",
    "generatedAt",
    "serviceId",
    "name",
    "owner",
    "status",
    "workflow",
    "fee"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "serviceId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "type": { "type": ["string", "null"] },
    "status": { "type": "string", "enum": ["active", "draft", "deprecated", "unknown"] },
    "owner": {
      "type": "object",
      "required": ["ministry"],
      "properties": {
        "ministry": { "type": "string", "minLength": 1 },
        "entity": { "type": ["string", "null"] },
        "directorate": { "type": ["string", "null"] },
        "serviceUnit": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "department": { "type": ["string", "null"] },
    "audience": { "type": ["string", "null"] },
    "eligibility": { "type": ["string", "null"] },
    "languages": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "url": { "type": ["string", "null"], "format": "uri" },
    "access": {
      "type": "object",
      "properties": {
        "channel": { "type": "string", "enum": ["offline", "online", "hybrid", "unknown"] },
        "submissionPoints": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "processingTime": {
      "type": "object",
      "properties": {
        "slaDays": { "type": ["number", "null"], "minimum": 0 },
        "rawText": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "documentsRequired": {
      "type": "array",
      "items": { "$ref": "./document-requirement.schema.json" }
    },
    "fee": { "$ref": "./fee.schema.json" },
    "workflow": { "$ref": "./workflow.schema.json" },
    "metrics": {
      "type": "object",
      "properties": {
        "frictionScore": { "type": ["number", "null"] },
        "documentsCount": { "type": ["integer", "null"], "minimum": 0 },
        "manualRequiredShare": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      },
      "additionalProperties": false
    },
    "supportContact": {
      "type": "object",
      "properties": {
        "phone": { "type": ["string", "null"] },
        "email": { "type": ["string", "null"], "format": "email" },
        "officeAddress": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
