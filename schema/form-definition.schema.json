{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dimbinirina.dev/schemas/procedures/form-definition.schema.json",
  "title": "Form Definition v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "serviceId",
    "catalogSchemaVersion",
    "generatedAt",
    "fields"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "serviceId": {
      "type": "string",
      "minLength": 1
    },
    "catalogSchemaVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "The catalog schemaVersion this form definition was derived from."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "version": {
      "type": ["string", "null"],
      "pattern": "^v?\\d+(\\.\\d+){0,2}$"
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["sectionId", "label", "order"],
        "properties": {
          "sectionId": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": ["string", "null"]
          },
          "order": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "fieldId",
          "type",
          "label",
          "required",
          "order"
        ],
        "properties": {
          "fieldId": {
            "type": "string",
            "pattern": "^field_[a-z0-9_-]+$"
          },
          "type": {
            "type": "string",
            "enum": [
              "text",
              "textarea",
              "number",
              "date",
              "select",
              "multiselect",
              "boolean",
              "file",
              "hidden"
            ]
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": ["string", "null"]
          },
          "placeholder": {
            "type": ["string", "null"]
          },
          "required": {
            "type": "boolean"
          },
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "sectionId": {
            "type": ["string", "null"],
            "description": "References a sectionId in the sections array."
          },
          "validation": {
            "type": "object",
            "properties": {
              "minLength": {
                "type": ["integer", "null"],
                "minimum": 0
              },
              "maxLength": {
                "type": ["integer", "null"],
                "minimum": 0
              },
              "pattern": {
                "type": ["string", "null"],
                "description": "Regex pattern the value must match."
              },
              "min": {
                "type": ["number", "null"],
                "description": "Minimum value for number or date fields."
              },
              "max": {
                "type": ["number", "null"],
                "description": "Maximum value for number or date fields."
              }
            },
            "additionalProperties": false
          },
          "options": {
            "type": "array",
            "description": "Required when type is select or multiselect.",
            "items": {
              "type": "object",
              "required": ["value", "label"],
              "properties": {
                "value": {
                  "type": "string"
                },
                "label": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "fileConstraints": {
            "type": "object",
            "description": "Required when type is file.",
            "properties": {
              "acceptedTypes": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "MIME types or extensions accepted (e.g. 'application/pdf', '.jpg')."
              },
              "maxSizeKb": {
                "type": ["integer", "null"],
                "minimum": 1
              },
              "multiple": {
                "type": "boolean",
                "description": "Whether multiple files can be uploaded for this field."
              }
            },
            "additionalProperties": false
          },
          "condition": {
            "type": "object",
            "description": "When present, this field is only shown when the condition is satisfied.",
            "required": ["fieldId", "operator", "value"],
            "properties": {
              "fieldId": {
                "type": "string",
                "description": "The fieldId of the controlling field."
              },
              "operator": {
                "type": "string",
                "enum": [
                  "equals",
                  "not_equals",
                  "contains",
                  "is_empty",
                  "is_not_empty"
                ]
              },
              "value": {
                "type": ["string", "number", "boolean", "null"]
              }
            },
            "additionalProperties": false
          },
          "mapsToDocumentTypeCode": {
            "type": ["string", "null"],
            "description": "Links a file field to a documentTypeCode in documentsRequired."
          },
          "mapsToWorkflowStepId": {
            "type": ["string", "null"],
            "description": "Links this field to the workflow step where it is consumed."
          }
        },
        "additionalProperties": false
      }
    },
    "source": {
      "type": "object",
      "properties": {
        "generator": {
          "type": ["string", "null"]
        },
        "sourceFile": {
          "type": ["string", "null"]
        },
        "parserVersion": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
